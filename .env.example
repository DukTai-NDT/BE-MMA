# Server
PORT=9999
JWT_SECRET=change_this_to_a_long_random_secret

# Database
MONGODB_URI=mongodb://localhost:27017/football_booking_app

# CORS (comma-separated origins; native mobile ignores CORS)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4200

# VNPay sandbox
VNP_TMNCODE=YOUR_SANDBOX_TMN_CODE
VNP_HASH_SECRET=YOUR_SANDBOX_HASH_SECRET
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_API=https://sandbox.vnpayment.vn/merchant_webapi/api/transaction
# Leave blank for local dev and let backend infer host from the incoming request.
# For approved/public deployments use:
# VNP_RETURN_URL=https://your-public-domain/api/vnpay/return
VNP_RETURN_URL=
# Optional fallback if frontend cannot send deep link target dynamically.
FE_BASE=

# SMTP settings (example for Gmail – requires 2FA + App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="MMA Booking" <your@gmail.com>
